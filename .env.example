# ============================================================
# Amadeus Self-Service API — 免费注册获取实时机票数据
# ============================================================
#
# 注册步骤:
#   1. 访问 https://developers.amadeus.com/register
#   2. 填写信息创建免费账号（无需信用卡）
#   3. 登录后进入 My Apps → Create New App
#   4. 选择 "Self-Service" 计划（免费，2000 次/月）
#   5. 创建后即可获得 API Key 和 API Secret
#
# 环境说明:
#   test       — 测试环境，注册后立即可用（数据量有限）
#   production — 生产环境，需提交 App 审核通过（数据更全）
#   默认使用 test 环境，无需额外配置
# ============================================================

AMADEUS_API_KEY=your_api_key_here
AMADEUS_API_SECRET=your_api_secret_here
AMADEUS_ENV=test

# ============================================================
# FlightAPI.io — 实时航班搜索 API（前端直连）
# ============================================================
# 使用步骤:
#   1. 访问 https://flightapi.io 注册账号
#   2. 在 Dashboard 获取 API Key
#   3. 将下方 PLACEHOLDER 替换为真实 Key
#   4. 在 static/js/flightService.js 中将 ENABLE_REAL_API 设为 true
# ============================================================
VITE_FLIGHT_API_KEY="PLACEHOLDER"
